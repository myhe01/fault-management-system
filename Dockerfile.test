# Build stage
FROM ubuntu:24.04 AS build

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        ninja-build \
        ca-certificates \
        git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src

# Pre-fetch GoogleTest before copying sources so this layer gets cached
COPY test/CMakeLists.txt CMakeLists.txt
RUN cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release --no-warn-unused-cli \
    && cmake --build build --target googletest_fetch || true

# Copy project files
COPY include/ include/
COPY src/ src/
COPY test/ test/

RUN cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
    && cmake --build build --parallel

# Run stage
FROM ubuntu:24.04 AS run

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build /src/build/fms_tests /app/fms_tests

WORKDIR /app

ENTRYPOINT ["/app/fms_tests"]